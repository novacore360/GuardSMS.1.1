<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.GuardSMS" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/secondary</item>
        <item name="colorPrimaryVariant">@color/secondary_variant</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Card style -->
    <style name="GuardCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- Stat card -->
    <style name="StatCard" parent="GuardCard">
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Primary Button -->
    <style name="GuardButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/secondary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Outline Button -->
    <style name="GuardButtonOutline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/secondary</item>
        <item name="android:textColor">@color/secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Danger Button -->
    <style name="GuardButtonDanger" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/danger_bg</item>
        <item name="android:textColor">@color/danger</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Text Input -->
    <style name="GuardTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/card_border</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Tab style -->
    <style name="GuardTabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabBackground">@android:color/transparent</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabSelectedTextColor">@color/secondary</item>
        <item name="tabIndicatorColor">@color/secondary</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="tabMode">fixed</item>
        <item name="tabGravity">fill</item>
        <item name="android:background">@color/surface</item>
        <item name="tabTextAppearance">@style/TabText</item>
    </style>

    <style name="TabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- Bottom Nav -->
    <style name="BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/surface</item>
        <item name="itemIconTint">@drawable/bottom_nav_color</item>
        <item name="itemTextColor">@drawable/bottom_nav_color</item>
        <item name="elevation">8dp</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <!-- Chip -->
    <style name="StatusChip.Safe" parent="Widget.MaterialComponents.Chip.Action">
        <item name="android:textColor">@color/safe</item>
        <item name="chipBackgroundColor">@color/safe_bg</item>
        <item name="android:textSize">11sp</item>
        <item name="chipMinHeight">24dp</item>
        <item name="chipStartPadding">8dp</item>
        <item name="chipEndPadding">8dp</item>
    </style>

    <style name="StatusChip.Danger" parent="Widget.MaterialComponents.Chip.Action">
        <item name="android:textColor">@color/danger</item>
        <item name="chipBackgroundColor">@color/danger_bg</item>
        <item name="android:textSize">11sp</item>
        <item name="chipMinHeight">24dp</item>
    </style>

</resources>
